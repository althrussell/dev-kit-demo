# ---------------------------------------------------------------------------
# GridLens Queensland — environment configuration
# Copy to .env (or export in your shell) for the Databricks-connected mode.
# All variables are optional for the local synthetic demo.
# ---------------------------------------------------------------------------

# Databricks workspace
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_HTTP_PATH=

# Unity Catalog target (a new schema set is created for this demo)
DATABRICKS_CATALOG=anzgt_may
DATABRICKS_SCHEMA_BRONZE=energyq_bronze
DATABRICKS_SCHEMA_SILVER=energyq_silver
DATABRICKS_SCHEMA_GOLD=energyq_gold

# Volume for asset documents (inspection reports, drawings, standards, photos)
DATABRICKS_VOLUME_PATH=/Volumes/anzgt_may/energyq/asset_docs

# Lakebase (Postgres) — leave empty to use the local SQLite mock at data/lakebase/gridlens.db
LAKEBASE_DATABASE_URL=

# Genie Space ID — leave empty to use the deterministic gold-table fallback
GENIE_SPACE_ID=

# Agent Bricks supervisor endpoint — leave empty to use the local grounded simulation
AGENTBRICKS_SUPERVISOR_ENDPOINT=

# Mapbox public token (pk.*). Exposed to the frontend at build time via Vite.
# When set, GridLens uses Mapbox dark vector tiles, globe projection, terrain,
# hillshading, sky/atmosphere, heatmaps and 3D buildings.
# When empty, the app falls back to MapLibre + CartoDB raster tiles.
VITE_MAPBOX_TOKEN=
MAPBOX_TOKEN=
